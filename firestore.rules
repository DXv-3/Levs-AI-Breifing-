rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['user', 'admin'])
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{uid}/chats
    // Document ID: {chatId}
    // Fields:
    //   - uid: string (required)
    //   - title: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users/{uid}/chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (required, enum: ['user', 'model'])
    //   - content: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "imvinnygilberti@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['uid', 'title', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp']) &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      
      match /chats/{chatId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidChat(request.resource.data);
        allow update: if isOwner(uid) && isValidChat(request.resource.data);
        allow delete: if isOwner(uid);

        match /messages/{messageId} {
          allow read: if isOwner(uid) || isAdmin();
          allow create: if isOwner(uid) && isValidMessage(request.resource.data);
        }
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
